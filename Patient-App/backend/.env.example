# ─────────────────────────────────────────────────────────────
# PsychAI Backend   Environment Variables
# Copy this to .env and fill in your real values.
# NEVER commit .env to GitHub.
# ─────────────────────────────────────────────────────────────

# ── Groq API (FREE   get at console.groq.com) ────────────────
# Free tier: 14,400 requests/day · No credit card needed
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Twilio (Silent crisis calls to guardian) ─────────────────
# $15 free trial credit   verify guardian number in console first
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# ── Supabase (use SERVICE ROLE key here   never in mobile app) ──
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
